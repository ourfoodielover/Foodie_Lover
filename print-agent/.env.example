# ── Foodie Lover Print Agent — configuration ────────────────────────────────
# Copy this file to .env and fill in your values.

# Base URL of the deployed Foodie Lover app (no trailing slash)
APP_BASE_URL=https://your-restaurant.example.com

# Restaurant ID (matches NEXT_PUBLIC_RESTAURANT_ID in the web app)
RESTAURANT_ID=rest_default

# Shared secret — must match PRINT_AGENT_KEY in the web app's environment
PRINT_AGENT_KEY=change-me-to-a-long-random-string

# How often to poll for new print jobs, in milliseconds
POLL_INTERVAL_MS=4000

# ── Printer connection (network ESC/POS, e.g. Epson TM-T20/T81/T88, port 9100) ──
PRINTER_IP=192.168.1.50
PRINTER_PORT=9100

# Paper width in characters for 80mm paper at default font (Font A, 12cpi)
PRINTER_CHARS_PER_LINE=42

# Optional: which printer station this agent serves (matches print_jobs.printer_id)
# Leave unset / "default" for a single-printer setup.
PRINTER_STATION_ID=default

# Restaurant name printed on the ticket header
RESTAURANT_NAME=Foodie Lover
